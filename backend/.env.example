# Telegram Bot (обязательно для server_lite.py и bot.py)
BOT_TOKEN=[REDACTED]

# SoundCloud API (обязательно для SoundCloud-only режима)
# Получение OAuth token client_credentials и кэш токена на 1 час.
# SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
# SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret
# SOUNDCLOUD_TOKEN_CACHE_SECONDS=3600

# VK API (обязательно для поиска и стриминга)
# Один токен (legacy):
# VK_TOKEN=[REDACTED]
# Несколько токенов, round-robin (на сервере 7 токенов, пик ~119 пользователей):
# VK_TOKENS=[REDACTED]
# Восстановление из локального бэкапа (файл на устройстве до удаления токенов): см. backend/vk_tokens_list.txt.example.
# Либо скопируй содержимое в backend/vk_tokens_list.txt, либо передай путь к файлу бэкапа:
#   bash scripts/vk_tokens_merge_for_env.sh
#   bash scripts/vk_tokens_merge_for_env.sh ~/путь/к/твоему_бэкапу.txt
# и вставь выведённую строку VK_TOKENS=... в secrets.env на VPS.
# С прокси: VK_TOKENS=[REDACTED]
# User-Agent на токен (Kate vs официальное приложение — разные строки; несовпадение → урезанные ответы, часто без обложек).
# Не используйте запятую как разделитель списка: внутри UA тоже есть запятые — список ломался.
# Варианты:
#   VK_USER_AGENTS_JSON=["KateMobileAndroid/56 lite-460 (Android 11; SDK 30; arm64-v8a; …; ru)","VKAndroidApp/8.17-…"]
#   VK_USER_AGENTS=полный_UA_1|||полный_UA_2|||полный_UA_3   (порядок = порядок токенов в VK_TOKENS)
# Если в списке ровно одна строка — она применяется ко всем токенам в VK_TOKENS.
# Устаревшее: VK_USER_AGENTS=ua1,ua2 — только если в строках UA нет запятых.
# Дефолт в коде — Kate Mobile; для токена официального приложения ВК задайте VK_USER_AGENT (например VKAndroidApp/...).
# Плюс https=1 и device_id подставляются в коде; реальный device_id с телефона — VK_DEVICE_ID=...
# X-VK-Android-Client=new; отключить: VK_X_VK_ANDROID_CLIENT=
# VK_X_VK_ANDROID_CLIENT=new
# VK_DEVICE_ID=
# VK_DEVICE_ID_RANDOM=0
# Воркеры (1 воркер = 1 ключ = 1 IP к VK). Ключ хранится в env воркера, бэкенд шлёт method+params.
# Почасовой лимит на токен/воркер: 0 = выключен (достаточно round-robin + 3 req/s на ключ).
# RATE_VK_PER_TOKEN_PER_HOUR=0
# VK_WORKER_URLS=https://worker-1.example.com/vk,https://worker-2.example.com/vk,...
# Таймаут запроса к воркеру (сек); быстрый failover на другой воркер при зависании.
# VK_WORKER_TIMEOUT=15
# VK: макс. запросов в секунду на один ключ (лимит VK 3). Ограничение — скользящее окно 1 с по ключу (round-robin).
# VK_MAX_RPS_PER_TOKEN=3
# Доп. пауза (сек) после 3 req на ключ: 0 = не использовать (та же логика, что у воркеров по IP). Ранее 1.5.
# VK_THROTTLE_DURATION=0
# Общий User-Agent по умолчанию (если для токена не задан отдельный в VK_USER_AGENTS)
VK_USER_AGENT=KateMobileAndroid/56 lite-460 (Android 4.4.2; SDK 19; x86; unknown Android SDK built for x86; en)

# Сервер (server_lite.py). Хостинг: 8000, nginx проксирует с 80.
APP_PORT=8000

# YouTube: прокси /api/music/youtube-direct, прогрев URL в Redis, полный M4A в mp3_cache/yt_{id}.m4a (LRU).
# YOUTUBE_WARM_CONCURRENCY=6
# YOUTUBE_WARM_STAGGER_SEC=0.08
# YT_DISK_CACHE_MAX_FILES=500

# Масштабирование: лимит одновременных запросов к бэкенду (дефолт 10000 для ~10k онлайн).
# LIMIT_CONCURRENCY=10000

# Rate limit поиска для live-запросов к VK (мягкий лимит с бэкоффом).
# Считается только для живых походов к VK (кэш Redis/in-memory не учитывается).
# RATE_SEARCH=8          # базовый минимум живых поисков/окно на пользователя
# RATE_WINDOW_SEC=60     # окно для live-поиска (сек)
# RATE_LOGIN=15
# RATE_ANALYTICS=120
# Без воркеров: глобальный лимит запросов к VK с сервера. Round-robin по ключам (каждый ключ до 3 req/s).
# RATE_VK_GLOBAL_RPS=3          # при 1 токене. При 7 токенах ставь 21 (= 7×3), иначе используешь 1/7 ёмкости.
# RATE_VK_GLOBAL_PER_HOUR=0     # почасовой лимит без воркеров: 0 = выключен.
# RATE_VK_PER_IP_PER_HOUR=500   # с одного клиента (user_id/IP) в час для resolve/download. Дефолт 500 по расчёту ниже.
#   Расчёт: 7 токенов × 3 req/s × 3600 с = 75 600 запросов к VK/час. При hit кэша ~90% → 75600/0.1 = 756k запросов к бэку/час.
#   При 400 активных юзерах: 756000/400 ≈ 1890/юзера. Ставим 500 (запас). Макс в коде: 2000.
# Дневной лимит VK-поиска: 50 для всех, 100 — только для купивших нашу подписку (список SUBSCRIBER_TG_IDS).
# Telegram Premium ни на что не влияет.
# RATE_VK_PER_USER_PER_DAY=50        # обычные пользователи. 0 = выключен.
# RATE_VK_PER_USER_SUB_PER_DAY=100   # подписчики (наша подписка). 0 = как у обычных.
# SUBSCRIBER_TG_IDS=123,456          # tg id купивших подписку (пока подписка без отдельного бэкенда — ручной список).
# DAILY_LIMIT_EXEMPT_USERNAMES=povariwe  # юзернеймы без дневного лимита (через запятую, без @).
# Для тяжёлых пользователей можно поднять RATE_SEARCH до 120–200 (но это увеличит давление на VK API).

# Нагрузочный тест: обход rate limit только на тестовом инстансе, не на проде.
# RATE_LIMIT_DISABLED=1   — отключить rate limit поиска (все запросы проходят).
# LOAD_TEST_SECRET=secret — запросы с заголовком X-Load-Test: secret не лимитируются по поиску.

# Публичный URL приложения (для webhook и кнопки PLAY). При деплое подставляется https://tgplay.fun
# WEBAPP_URL=https://tgplay.fun
# Дополнительные Origin для CORS (через запятую), если мини-приложение открывают с другого домена.
# tgplay.fun уже добавлен в коде рядом с каноническим URL; при необходимости: WEBAPP_CORS_ORIGINS=https://www.tgplay.fun

# Telegram Login (OIDC) для веб/PWA: проверка id_token с oauth.telegram.org + выдача сессионного JWT (Authorization: Bearer).
# TELEGRAM_OAUTH_CLIENT_ID — Bot ID (тот же client_id, что в BotFather / в Telegram.Login.init).
#
# TGPLAY_WEB_SESSION_SECRET — ОБЯЗАТЕЛЕН для веб/PWA OAuth: подпись сессионного JWT (не путать с BOT_TOKEN).
# Сгенерируй сам: openssl rand -hex 32  — и пропиши в backend/.env (локально) или /root/.tgplay/secrets.env (VPS, см. secrets_env.py).
# Без этой строки: POST /api/auth/telegram и POST /api/auth/telegram/code → 503; API с Authorization: Bearer — без пользователя.
# Mini App (Authorization: tma) и вебхук бота (/start) этим секретом не пользуются.
# TGPLAY_WEB_SESSION_DAYS=30 — срок жизни Bearer-сессии (1–90).
# TELEGRAM_OAUTH_CLIENT_ID=8575565887
# TELEGRAM_OAUTH_CLIENT_SECRET=из_BotFather_Web_Login_не_в_git — обязателен для входа с сайта (PKCE redirect → POST /api/auth/telegram/code).
# TGPLAY_WEB_SESSION_SECRET=подставь_вывод_openssl_rand_hex_32
# RATE_AUTH_TELEGRAM_OAUTH=20 — лимит POST /api/auth/telegram и /api/auth/telegram/code с одного IP за окно rate limit (как RATE_LOGIN).
# В BotFather → Web Login добавь Allowed redirect URI для каждого origin, например:
#   https://tgplay.fun/auth/telegram/callback
#   https://www.tgplay.fun/auth/telegram/callback
#   https://tgplay.fun/auth/telegram/callback

# Базовый URL только для setWebhook (HTTPS без слэша). Имеет приоритет над tgplay.fun / WEBAPP_URL при выборе хоста
# (см. server_lite._set_telegram_webhook_to_our_server). Если в getWebhookInfo «Connection timed out» до tgplay.fun,
# а рабочий HTTPS — на другом имени, задайте сюда этот базовый URL.
# TELEGRAM_WEBHOOK_BASE_URL=https://tgplay.fun

# Секрет webhook Telegram (опционально). Задай в BotFather при setWebhook — тогда сервер будет проверять заголовок X-Telegram-Bot-Api-Secret-Token.
# TELEGRAM_WEBHOOK_SECRET=your_secret_from_botfather
# TGPLAY_AGENT_DEBUG=1 — опциональная NDJSON-диагностика (backend/logs/agent-debug.ndjson); без флага выкл.
# TGPLAY_AGENT_DEBUG_LOG=/path/to/custom.ndjson
# TELEGRAM_WEBHOOK_HEALTH_RETRIES=5 — сколько раз опрашивать каждый кандидат /api/health при setWebhook на старте (флап сети)
# TELEGRAM_WEBHOOK_HEALTH_RETRY_DELAY_SEC=2.0 — пауза между попытками (сек)
# TG_BOT_POLLING=1 — только для локального python bot.py (long polling). Иначе bot.py выставит меню и выйдет, webhook не трогает (его обслуживает server_lite).

# Аналитика: ключ для страницы /admin/stats. Задай свой (в коде ключа нет). При деплое подставится на сервер, в лог выведется твоя ссылка.
# ANALYTICS_ADMIN_KEY=[REDACTED]
# Журнал ЛС с ботом (текст + вложения, только private): GET /api/admin/bot-incoming?key=... , GET .../bot-incoming/{id}?key=... , файл: .../bot-incoming/{id}/file?key=...&file_index=0

# Автоввод капчи VK (rucaptcha.com / 2captcha.com). Без ключа — при капче токен уходит в cooldown.
# RUCAPTCHA_KEY=your_rucaptcha_api_key_here

# Redis (общий кэш поиска и треков; обязателен для режима Redis-воркеров).
# Если не задан — in-memory кэш в server_lite.py.
# REDIS_URL=redis://localhost:6379/0
# Режим Redis-воркеров: 1 = запросы к VK через очереди Redis, воркеры backend/vk_worker. Иначе — прямой вызов или HTTP VK_WORKER_URLS.
# VK_USE_REDIS_WORKERS=1

# Кэш: сколько треков из результата поиска пререзолвить в фоне (URL в Redis) — меньше обращений к воркеру.
# SEARCH_PRESOLVE_TOP_N=10
# Кэш ответов /api/music/search (Redis + память): жёсткий TTL ключа, сек (дефолт 86400 = 24 ч; в коде раньше было 7 сут).
# SEARCH_CACHE_TTL_SEC=86400
# SWR: после этого возраста отдаём кэш и обновляем в фоне, сек (дефолт 3600). 0 = без фонового обновления.
# SEARCH_CACHE_SOFT_TTL_SEC=3600
# Макс. записей in-memory LRU поиска (100–200000).
# SEARCH_CACHE_MAX_ENTRIES=50000
# Догрузка обложек для кэшированной выдачи без cover_url через audio.getById.
# SEARCH_CACHE_COVER_BACKFILL=1
# SEARCH_CACHE_COVER_BACKFILL_MAX=100
#
# Artwork provider-chain fallback (если VK вернул урезанные audio-объекты без album/thumb):
# SEARCH_ARTWORK_FALLBACK_ENABLED=1
# SEARCH_ARTWORK_FALLBACK_MAX=10
# SEARCH_ARTWORK_FALLBACK_CACHE_MAX=4000
# SEARCH_ARTWORK_AGGRESSIVE_MODE=1         # 1 = перебираем источники до первого результата/конца цепочки
# SEARCH_ARTWORK_MIN_CONFIDENCE=60         # 0..100 (баланс: меньше левых iTunes, но не «убить» кириллицу)
# SEARCH_ARTWORK_STAGE_THRESHOLD_PCT=70    # если после VK+Redis >= порога, внешние источники не запускаем
# TRACK_ARTWORK_REDIS_TTL_SEC=2592000      # TTL кэша cover_url по track_id (сек)
# Ключи/токены (опционально для расширенного доступа):
# LASTFM_API_KEY=...
# SPOTIFY_BEARER_TOKEN=...
# VK_WEB_SESSION_COOKIE=remixsid=...; remixlang=0; ...
# VK_WEB_USER_AGENT=Mozilla/5.0 (...) Chrome/145.0.0.0 Safari/537.36
# Порядок провайдеров (строгий перебор): iTunes -> Deezer -> Spotify API -> Spotify page ->
# Last.fm API -> Last.fm page -> Bandcamp -> SoundCloud -> YandexMusic -> BOOM ->
# m.vk search -> vk.com search -> CoverArtArchive.
# TTL кэша метаданных треков (часы). Больше — реже запросы к VK за getById.
# TRACK_INFO_CACHE_TTL_HOURS=2
# TTL метаданных треков в Redis (подборки / быстрый resolve), сек — по умолчанию 14 суток
# TRACK_META_REDIS_TTL_SEC=1209600
# Макс. треков за один запрос «каталог исполнителя» (artist_catalog=1), 100–900
# ARTIST_CATALOG_MAX_TRACKS=600
# Версия ключей кэша (при смене структуры ответа — старые ключи перестают читаться).
# CACHE_VERSION=v1
# Негативный кэш (трек удалён / geo / приватный): TTL в секундах (5–30 мин).
# NEGATIVE_CACHE_TTL_SEC=600

# Рекомендации /api/music/recommendations: общий кэш по seed (все пользователи), лимит живых VK getRecommendations в минуту (Redis).
# 0 = без лимита (только singleflight + кэш). При ~10k онлайн держи Redis и лимит 30–120/мин под ваш пул ключей.
# RECOMMENDATIONS_CACHE_TTL_SEC=86400
# RECOMMENDATIONS_LOCK_SEC=30
# RECOMMENDATIONS_VK_MAX_PER_MINUTE=60
# RECOMMENDATIONS_POPULAR_CACHE_TTL_SEC=3600
# RECOMMENDATIONS_NEGATIVE_CACHE_TTL_SEC=600
# RECOMMENDATIONS_VK_LOCAL_CONCURRENCY=6
# RECOMMENDATIONS_VK_FETCH_COUNT=80
# Персональные рекомендации (/personal): число равномерно распределённых seed по всему избранному (3–16).
# RECOMMENDATIONS_PERSONAL_MAX_SEEDS=12
#
# Якорь: N уникальных исполнителей с долями избранное / кастом / поиск; кандидаты VK — audio.search по жанру (не getRecommendations).
# REC_STRICT_ANCHOR_TRACKS=10
# REC_STRICT_ANCHOR_SEARCHES=5
# REC_ANCHOR_PCT_MAIN=60
# REC_ANCHOR_PCT_CUSTOM=30
# Нейтральный q для audio.search при отборе по genre_id (не подписи жанров).
# REC_GENRE_SEARCH_NEUTRAL_Q=a
# При жанровом фильтре оставлять треки без genre_id в мете (1) или отсекать (0).
# REC_GENRE_FILTER_KEEP_UNKNOWN=1
# Персональные реки и «Моя волна»: по умолчанию без VK (YTM radio + поиск). Вернуть VK: REC_PERSONAL_SKIP_VK=0
# REC_PERSONAL_SKIP_VK=0
#
# Отладка рекомендаций: структурные логи logger.info с префиксом «rec_trace» (источник vk / search_affinity / collab, seed, genre, taste_score).
# Включить: REC_TRACE=1. Если задать REC_TRACE_USER_IDS — логируются только эти telegram_user_id (через запятую); иначе при REC_TRACE=1 — все пользователи (шумно).
# REC_TRACE=1
# REC_TRACE_USER_IDS=123456789,987654321
# REC_TRACE_TOP_K=30
